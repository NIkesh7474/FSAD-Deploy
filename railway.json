{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd FSAD-Project-main && npm ci && npm run build"
  },
  "deploy": {
    "startCommand": "cd FSAD-Project-main && npm start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
